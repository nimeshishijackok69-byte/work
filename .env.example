# ---------------------------------------------------------------
# Supabase (required)
# ---------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------
# NextAuth.js (required)
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32
# In production set NEXTAUTH_URL to the deployed site URL.
# ---------------------------------------------------------------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# ---------------------------------------------------------------
# Resend (required for email delivery)
# ---------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=FormFlow <onboarding@resend.dev>
RESEND_REPLY_TO_EMAIL=
RESEND_TEST_EMAIL=

# ---------------------------------------------------------------
# Optional bootstrap overrides (used by scripts/bootstrap-admin.mjs)
# ---------------------------------------------------------------
# BOOTSTRAP_ADMIN_EMAIL=admin@formflow.com
# BOOTSTRAP_ADMIN_PASSWORD=change-me
# BOOTSTRAP_ADMIN_NAME=Super Admin
